# Node environment
NODE_ENV=
PORT=

# Database connection
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=
# Used by node-pg-migrate CLI. The application still uses DB_* above.
DATABASE_URL=

# Redis connection
REDIS_URL=


JWT_SECRET=
JWT_EXPIRES_IN=15m

# =========================
# OAuth Providers
# =========================
OAUTH_PUBLIC_BASE_URL=http://localhost:3001
OAUTH_STATE_TTL_SECONDS=600
OAUTH_EXCHANGE_CODE_TTL_SECONDS=300
OAUTH_FRONTEND_REDIRECT_ALLOWLIST=http://localhost:5173/signin/callback
OAUTH_ENABLED_PROVIDERS=google,github
OAUTH_DEFAULT_PROFILE_ID=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_PATH=/api/auth/oauth/google/callback

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_PATH=/api/auth/oauth/github/callback

# =========================
# Email / Mail Provider
# =========================

# General
MAIL_PROVIDER=smtp          # smtp | ses | sendgrid (future-proof)
MAIL_FROM_NAME=Auth210
MAIL_FROM_EMAIL=no-reply@yourdomain.com

# SMTP (default implementation)
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false           # true for 465, false for 587
MAIL_USER=
MAIL_PASSWORD=

# Optional (used for links in emails)
APP_BASE_URL=http://localhost:3000
API_KEY=
