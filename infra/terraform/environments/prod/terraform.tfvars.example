project_name = "auth-service"
environment  = "prod"
aws_region   = "us-east-1"

# Use the manual deploy convention: git-<short-commit-sha>
container_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/auth-service-prod:git-a1b2c3d"

budget_alert_email = "lokermia@gmail.com"
budget_limit_usd   = 30

allowed_cidr_blocks = ["0.0.0.0/0"]

db_name           = "auth210"
db_username       = "auth210"
db_instance_class = "db.t4g.micro"

app_environment_variables = {
  JWT_EXPIRES_IN                    = "15m"
  OAUTH_PUBLIC_BASE_URL             = ""
  OAUTH_STATE_TTL_SECONDS           = "600"
  OAUTH_EXCHANGE_CODE_TTL_SECONDS   = "300"
  OAUTH_FRONTEND_REDIRECT_ALLOWLIST = ""
  OAUTH_ENABLED_PROVIDERS           = "google,github"
  OAUTH_DEFAULT_PROFILE_ID          = ""
  GOOGLE_OAUTH_CALLBACK_PATH        = "/api/auth/oauth/google/callback"
  GITHUB_OAUTH_CALLBACK_PATH        = "/api/auth/oauth/github/callback"
  MAIL_PROVIDER                     = "smtp"
  MAIL_FROM_NAME                    = "Auth210"
  MAIL_FROM_EMAIL                   = "no-reply@example.com"
  MAIL_HOST                         = ""
  MAIL_PORT                         = "587"
  MAIL_SECURE                       = "false"
  APP_BASE_URL                      = ""
}
